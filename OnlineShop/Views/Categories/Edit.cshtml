@model OnlineShop.Models.Category

@{
    ViewData["Title"] = "編輯類別";
}

<h1 class="text-center mt-4">編輯類別</h1>
<hr />

<div class="row justify-content-center mb-5">
    <div class="col-12 col-md-8 col-lg-5">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="SortOrder" />

            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label mb-1">類別名稱</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label class="control-label mb-2 fw-bold">類別圖片</label>

                @if (Model?.Image != null && Model.Image.Length > 0)
                {
                    <div class="mb-3 text-center p-3 shadow-sm" style="border: 2px dashed #e9ecef; border-radius: 12px;">
                        <img src="data:image/png;base64,@Convert.ToBase64String(Model.Image)" style="max-height: 120px; object-fit: contain;" />
                    </div>
                }

                <input type="file" name="imageFile" class="form-control" accept="image/*" />
                <small class="text-muted d-block mt-2">💡 若不更換圖片請留空。</small>
            </div>

            <div class="form-group mb-2 mt-4">
                <input type="submit" value="儲存變更" class="btn btn-primary w-100 py-2 fw-bold" />
            </div>
        </form>

        <div class="text-center mt-3">
            <a asp-action="Index" class="btn btn-secondary w-100 py-2">返回類別列表</a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}