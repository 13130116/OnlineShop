@model OnlineShop.Models.Category

@{
    ViewData["Title"] = "新增類別";
}

<div class="container mt-4">
    <h2>新增商品類別</h2>
    <hr />
    <div class="row">
        <div class="col-md-4">
            <form asp-action="CreateCategory">
                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label fw-bold">類別名稱</label>
                    <input asp-for="Name" class="form-control" placeholder="請輸入類別名稱..." required />
                </div>
                <div class="form-group">
                    <input type="submit" value="確認新增" class="btn btn-primary" />
                </div>
            </form>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-outline-secondary">返回商品列表</a>
    </div>
</div>