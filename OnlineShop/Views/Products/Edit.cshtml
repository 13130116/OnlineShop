@model OnlineShop.Models.Product

@{
    ViewData["Title"] = "編輯商品";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="text-center fw-bold mb-4">編輯商品</h2>

            @* 務必保留 enctype="multipart/form-data"，否則圖片無法上傳 *@
            <form asp-action="Edit" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CategoryId" />

                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label fw-bold">商品名稱</label>
                    <input asp-for="Name" class="form-control" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Price" class="control-label fw-bold">價格</label>
                    <input asp-for="Price" class="form-control" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Stock" class="control-label fw-bold">庫存</label>
                    <input asp-for="Stock" class="form-control" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Description" class="control-label fw-bold">商品描述</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold">更換商品圖片</label>
                    <input type="file" name="imageFile" class="form-control" accept="image/*" />
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary px-5">儲存修改</button>
                    <a asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="btn btn-link text-secondary">返回列表</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}