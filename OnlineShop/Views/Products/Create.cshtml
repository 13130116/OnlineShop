@model OnlineShop.Models.Product

@{
    ViewData["Title"] = "新增商品";
}

<h2 class="text-center fw-bold mt-4 mb-4">新增商品</h2>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0" style="background-color: #f8f9fa; border-radius: 12px;">
                <div class="card-body p-4">
                    <p class="text-muted small mb-4"><span class="text-danger">*</span> 表示必填欄位</p>

                    <form asp-action="Create" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <label class="control-label mb-1">商品名稱 <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" data-val="true" data-val-required="您尚未填入商品名稱" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="control-label mb-1">商品價格 <span class="text-danger">*</span></label>
                            <input type="number" step="any" name="Price" id="Price" class="form-control" value="@Model?.Price" data-val="true" data-val-required="您尚未填入商品價格" />
                            <span class="text-danger field-validation-valid fw-bold" data-valmsg-for="Price" data-valmsg-replace="true"></span>
                        </div>

                        <!-- 👇 補回商品庫存的輸入欄位 -->
                        <div class="form-group mb-3">
                            <label class="control-label mb-1">商品庫存 <span class="text-danger">*</span></label>
                            <input type="number" name="Stock" id="Stock" class="form-control" value="@Model?.Stock" data-val="true" data-val-required="您尚未填入商品庫存" />
                            <span class="text-danger field-validation-valid fw-bold" data-valmsg-for="Stock" data-valmsg-replace="true"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="control-label mb-1">商品類別 <span class="text-danger">*</span></label>
                            <select name="CategoryId" id="CategoryId" class="form-control" asp-items="ViewBag.CategoryId" data-val="true" data-val-required="您尚未填入商品類別">
                                <option value="">請選擇商品類別</option>
                            </select>
                            <span class="text-danger field-validation-valid fw-bold" data-valmsg-for="CategoryId" data-valmsg-replace="true"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="control-label mb-1">商品圖片 <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="file" name="imageFile" class="form-control" accept="image/*" />
                            </div>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Description" class="control-label mb-1">商品描述</label>
                            <textarea asp-for="Description" class="form-control" rows="5" id="editor"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="text-center mt-4">
                            <button type="submit" class="btn btn-primary px-5 rounded-pill">新增</button>
                            <a asp-action="Index" class="btn btn-link text-secondary ms-2">返回列表</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
    <script>
        ClassicEditor
            .create(document.querySelector('#editor'))
            .catch(error => {
                console.error(error);
            });
    </script>
}