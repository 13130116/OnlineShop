@model OnlineShop.Models.PaginatedList<OnlineShop.Models.Product>
@using Microsoft.AspNetCore.Http
@using OnlineShop.Helpers
@using OnlineShop.Models

@{
    var title = ViewData["Title"] ?? "商品列表";

    // 因為這頁已經拔除直接加購物車的功能，這行其實可以拿掉，但保留也不會影響效能
    var cart = Context.Session.GetObjectFromJson<List<CartItem>>("Cart") ?? new List<CartItem>();
}

<div class="text-center mb-5">
    <h1 class="display-5 fw-bold">
        📦 @title
    </h1>

</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

    <<div class="row justify-content-center mb-4">

    <div class="col-lg-8">

        <form asp-action="Index" method="get">

            <div class="input-group shadow-sm">

                <input type="text"
                       name="searchString"
                       class="form-control"
                       placeholder="🔍 請輸入商品名稱"
                       value="@Context.Request.Query["searchString"]" />

                <button type="submit" class="btn btn-primary">
                    搜尋
                </button>

                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn btn-success ms-4">
                        ＋ 新增商品
                    </a>
                }

            </div>

        </form>

    </div>

</div>

<table class="table table-hover table-bordered align-middle shadow-sm">
    <thead>
        <tr>
            <th>商品圖片</th>
            <th>商品名稱</th>
            <th>價格</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (item.Image != null)
                    {
                        var base64 = Convert.ToBase64String(item.Image);
                        var imgSrc = $"data:image/png;base64,{base64}";
                        <img src="@imgSrc" width="100" />
                    }
                    else
                    {
                        <img src="/images/default-phone.jpg" width="100" class="img-thumbnail" alt="預設商品圖" />
                    }
                </td>
                <td>@Html.DisplayFor(modelItem => item.Name)</td>
                <td>@item.Price.ToString("N0")</td>
                <td>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                            編輯
                        </a>
                    }

                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                        詳情
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                            刪除
                        </a>
                    }

                    <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary fw-bold shadow-sm ms-2">
                        🔍 選擇規格
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div>
    @if (Model.HasPreviousPage)
    {
        <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)">上一頁</a>
    }
    @if (Model.HasNextPage)
    {
        <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)">下一頁</a>
    }
</div>