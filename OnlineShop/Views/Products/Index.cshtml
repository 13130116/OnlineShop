@model OnlineShop.Models.PaginatedList<OnlineShop.Models.Product>
@using Microsoft.AspNetCore.Http
@using OnlineShop.Helpers
@using OnlineShop.Models

@{
    ViewData["Title"] = "Index";
    
    var cart = Context.Session.GetObjectFromJson<List<CartItem>>("Cart") ?? new List<CartItem>();
}

<h1>Index</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">新增商品</a>
    </p>
}

<form asp-action="Index" method="get">
    <div class="mb-3">
        <input type="text"
               name="searchString"
               class="form-control"
               placeholder="請輸入商品名稱">

        <button type="submit"
                class="btn btn-primary mt-2">
            搜尋
        </button>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>商品圖片</th>
            <th>商品名稱</th>
            <th>價格</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (item.Image != null)
                    {
                        var base64 = Convert.ToBase64String(item.Image);
                        var imgSrc = $"data:image/png;base64,{base64}";
                        <img src="@imgSrc" width="100" />
                    }
                    else
                    {
                        <span>無圖片</span>
                    }
                </td>
                <td>@Html.DisplayFor(modelItem => item.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.Price)</td>
                <td>
                    @{
                       
                        var cartItem = cart.FirstOrDefault(c => c.ProductId == item.Id);
                        var inCartQty = cartItem != null ? cartItem.Quantity : 0;
                        var availableStock = item.Stock - inCartQty;
                        var defaultQty = availableStock > 0 ? 1 : 0;
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id">編輯</a>
                        <text> | </text>
                    }

                    <a asp-action="Details" asp-route-id="@item.Id">詳情</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <text> | </text>
                        <a asp-action="Delete" asp-route-id="@item.Id">刪除</a>
                    }


                    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-inline-flex align-items-center ms-2">
                        <input type="hidden" name="productId" value="@item.Id" />
                        <input type="hidden" name="name" value="@item.Name" />
                        <input type="hidden" name="price" value="@item.Price" />
                        <input type="hidden" name="stock" value="@item.Stock" />

                        <input type="number" name="quantity"
                               value="@defaultQty"
                               min="@(availableStock > 0 ? 1 : 0)"
                               max="@availableStock"
                               class="form-control form-control-sm me-1"
                               style="width: 70px;"
                               title="請輸入數量"
                               @(availableStock <= 0 ? "readonly" : "") />

                        <button type="submit" class="btn btn-sm @(availableStock <= 0 ? "btn-secondary" : "btn-success")" @(availableStock <= 0 ? "disabled" : "")>
                            @(availableStock <= 0 ? "已達上限" : "加入購物車")
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<div>
    @if (Model.HasPreviousPage)
    {
        <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)">上一頁</a>
    }
    @if (Model.HasNextPage)
    {
        <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)">下一頁</a>
    }
</div>