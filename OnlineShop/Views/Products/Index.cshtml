@model IEnumerable<OnlineShop.Models.Product>

@{
    ViewData["Title"] = "商品列表";
}

<div class="container mt-3">
    <h2 class="text-center fw-bold mb-3">您已進入 @ViewBag.CategoryName 商品區</h2>

    <div class="row justify-content-center mb-4">
        <div class="col-md-8">
            <form asp-action="Index" method="get" class="d-flex gap-2 align-items-center">
                <input type="hidden" name="categoryId" value="@Context.Request.Query["categoryId"]" />
                <input type="text" name="searchString" class="form-control rounded-pill px-4" placeholder="搜尋商品名稱" />
                <button type="submit" class="btn btn-primary px-4 rounded-pill">搜尋</button>
                @if (User.IsInRole("Admin"))
                {
                    @* 新增商品時也帶入 categoryId，這樣預設類別才會選對 *@
                    <a asp-action="Create" asp-route-categoryId="@Context.Request.Query["categoryId"]" class="btn btn-dark px-4 rounded-pill text-nowrap">+ 新增商品</a>
                }
            </form>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table align-middle shadow-sm bg-white rounded">
            <thead class="table-light">
                <tr>
                    <th style="width: 15%">商品圖片</th>
                    <th style="width: 40%">商品名稱</th>
                    <th style="width: 20%">價格</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th style="width: 25%">操作</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (item.Image != null)
                            {
                                <img src="data:image/png;base64,@Convert.ToBase64String(item.Image)"
                                     style="width:50px; height:50px; object-fit:cover;" class="rounded" />
                            }
                            else
                            {
                                <span class="text-muted">無圖</span>
                            }
                        </td>
                        <td class="fw-bold">@item.Name</td>
                        <td class="fw-bold" style="color: black !important;">@item.Price?.ToString("C0")</td>
                        @if (User.IsInRole("Admin"))
                        {
                            <td>
                                @* 這裡補上 asp-route-categoryId 讓編輯和刪除知道要跳回哪一頁 *@
                                <a asp-action="Edit" asp-route-id="@item.Id" asp-route-categoryId="@Context.Request.Query["categoryId"]" class="btn btn-sm btn-outline-secondary">編輯</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" asp-route-categoryId="@Context.Request.Query["categoryId"]" class="btn btn-sm btn-outline-danger">刪除</a>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>