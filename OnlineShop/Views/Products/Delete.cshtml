@model OnlineShop.Models.Product

@{
    ViewData["Title"] = "刪除商品";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="alert alert-danger shadow-sm" role="alert">
                <h4 class="alert-heading fw-bold">警告！</h4>
                您即將刪除這個商品。此動作執行後將<strong>完全無法復原</strong>。
            </div>

            <div class="card shadow-sm border-0 mt-3">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold border-bottom pb-2 mb-4">即將刪除的商品資訊</h5>
                    <dl class="row">
                        <dt class="col-sm-3 fw-bold">商品名稱</dt>
                        <dd class="col-sm-9">@Model.Name</dd>
                        <dt class="col-sm-3 fw-bold">商品價格</dt>
                        <dd class="col-sm-9">@Model.Price?.ToString("C0")</dd>
                    </dl>

                    <form asp-action="Delete" class="mt-4">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" name="categoryId" value="@Model.CategoryId" />

                        <button type="submit" class="btn btn-danger px-4 rounded-pill" onclick="return confirm('確定要刪除嗎？');">
                            確認刪除
                        </button>

                        <a asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="btn btn-outline-secondary px-4 rounded-pill ms-2">取消並返回</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>