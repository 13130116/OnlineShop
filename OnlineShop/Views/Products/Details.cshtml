@model OnlineShop.Models.Product

@{
    ViewData["Title"] = "商品詳情";
}

<h1>商品詳情</h1>

<div>
    <h4>商品資訊</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Price)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Price)
        </dd>
    </dl>
</div>
<div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model?.Id">
            編輯商品
        </a>
        <span>|</span>
    }

    <a asp-action="Index">
        返回商品列表
    </a>
</div>


<hr />
<h3>商品規格</h3>
<h3>留言區</h3>

@if (Model.Comments != null && Model.Comments.Any())
{
    @foreach (var c in Model.Comments)
    {
        <div class="border p-2 mb-2">
            <p>@c.Content</p>
            <small>@c.CreatedAt</small>
        </div>
    }
}
else
{
    <p>目前沒有留言</p>
}

<hr />
<hr />



@if (Model.ProductVariants != null && Model.ProductVariants.Any())
{
    <table class="table table-bordered text-center">
        <thead>
            <tr>
                <th>顏色</th>
                <th>容量</th>
                <th>價格</th>
                <th>庫存</th>
                <th>購買</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.ProductVariants)
            {
                <tr>

                    <td>@item.Color</td>

                    <td>@item.Capacity</td>

                    <td>$@item.Price</td>

                    <td>
                        @if (item.Stock > 0)
                        {
                            <span class="text-success">
                                剩餘 @item.Stock 件
                            </span>
                        }
                        else
                        {
                            <span class="text-danger">
                                已售罄
                            </span>
                        }
                    </td>

                    <td>

                        @if (item.Stock > 0)
                        {
                            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-inline">
                                <input type="hidden" name="productId" value="@Model.Id" />
                                <input type="hidden" name="variantId" value="@item.Id" />

                                <button type="submit" class="btn btn-primary">
                                    加入購物車
                                </button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-secondary" disabled>
                                已售罄
                            </button>

                            <form asp-action="AddRestockNotification" method="post" class="d-inline">
                                @Html.AntiForgeryToken()

                                <input type="hidden" name="productVariantId" value="@item.Id" />
                                <input type="hidden" name="productId" value="@Model.Id" />

                                <button type="submit" class="btn btn-outline-danger ms-2">
                                    到貨通知我
                                </button>
                            </form>
                        }

                    </td>

                </tr>
            }
        </tbody>

    </table>
}
else
{
    <p>目前沒有商品規格</p>
}
<h4>新增留言</h4>

<form asp-action="AddComment" method="post">
    <input type="hidden" name="ProductId" value="@Model.Id" />

    <div class="form-group">
        <textarea name="Content" class="form-control" placeholder="輸入留言"></textarea>
    </div>

    <button type="submit" class="btn btn-primary mt-2">
        送出留言
    </button>

</form>

