@{
    ViewData["Title"] = "登入";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="card border-0 shadow-lg p-5" style="width: 100%; max-width: 400px; border-radius: 24px; background-color: #ffffff;">

        <div class="text-center mb-4">
            <h1 class="fw-bold display-6 mb-2" style="letter-spacing: -1px;">會員登入</h1>
            <p class="text-muted small">歡迎回到會員區，立即同步您的購物車</p>
        </div>

        <!-- 這裡已經幫你把 asp-action 和 asp-route-returnurl 加進組員漂亮的表單中了 -->
        <form method="post" asp-action="Login" asp-route-returnurl="@ViewData["ReturnUrl"]">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger border-0 rounded-3 small py-2 mb-3 shadow-sm" role="alert">
                    ⚠ @ViewBag.Error
                </div>
            }

            <div class="mb-3">
                <label class="form-label text-muted small fw-bold">電子郵件信箱</label>
                <input type="email" name="email" class="form-control form-control-lg py-2 px-3 shadow-sm"
                       placeholder="Email" style="border-radius: 12px; border: 1px solid #e2e8f0;" required />
            </div>

            <div class="mb-4">
                <label class="form-label text-muted small fw-bold">密碼</label>
                <input type="password" name="password" class="form-control form-control-lg py-2 px-3 shadow-sm"
                       placeholder="Password" style="border-radius: 12px; border: 1px solid #e2e8f0;" required />
            </div>

            <button type="submit" class="btn btn-primary w-100 py-3 fw-bold fs-6 mb-3 shadow-sm" style="border-radius: 999px;">
                登入
            </button>

            <div class="text-center mt-2">
                <span class="text-muted small">還不是會員嗎？</span>
                <a asp-controller="Account" asp-action="Register" class="text-success small fw-bold text-decoration-none hover-bold">免費註冊 ➔</a>
            </div>
        </form>
    </div>
</div>