@model OnlineShop.Models.Consultation

@{
    ViewData["Title"] = "回覆諮詢";
}

<h1>回覆諮詢</h1>

<hr />

<div class="row">
    <div class="col-md-6">

        <form asp-action="Edit">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label class="control-label">
                    會員帳號
                </label>

                <input asp-for="UserId"
                       class="form-control"
                       readonly />
            </div>


            <div class="form-group mb-3">
                <label class="control-label">
                    提問內容
                </label>

                <textarea asp-for="Question"
                          class="form-control"
                          rows="4"
                          readonly></textarea>
            </div>


            <div class="form-group mb-3">
                <label asp-for="Answer" class="control-label">
                    管理員回覆
                </label>

                <textarea asp-for="Answer"
                          class="form-control"
                          rows="5"
                          placeholder="請輸入回覆內容"></textarea>

                <span asp-validation-for="Answer"
                      class="text-danger"></span>
            </div>


            <button type="submit" class="btn btn-primary">
                送出回覆
            </button>

        </form>

    </div>
</div>


<div class="mt-3">
    <a asp-action="Index">返回諮詢列表</a>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}