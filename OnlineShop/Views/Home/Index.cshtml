@model IEnumerable<OnlineShop.Models.Category>

@{
    ViewData["Title"] = "首頁";
}

<!-- 縮小標題區塊的垂直間距 -->
<div class="text-center my-3 py-2">
    <h1 class="display-4 fw-bold mb-1">歡迎來到愛瘋屋</h1>
    <p class="fs-5 text-muted">請選擇商品類別</p>
</div>

<div class="container mb-4">
    <div class="row row-cols-1 row-cols-md-3 g-3 justify-content-center">
        @if (Model != null && Model.Any())
        {
            @foreach (var category in Model)
            {
                <div class="col position-relative">
                    @if (User.IsInRole("Admin"))
                    {
                        <form asp-controller="Categories" asp-action="Delete" asp-route-id="@category.Id" method="post" class="position-absolute" style="top: 10px; right: 20px; z-index: 10;" onsubmit="return confirm('確定要刪除「@category.Name」嗎？');">
                            <button type="submit" class="btn btn-sm btn-light border shadow-sm rounded-circle" style="width: 28px; height: 28px; font-size: 12px;">✕</button>
                        </form>
                    }

                    <a asp-controller="Products" asp-action="Index" asp-route-categoryId="@category.Id" class="text-decoration-none text-dark">
                        <!-- 稍微調小 padding -->
                        <div class="card home-category-card h-100 shadow-sm p-2 text-center">
                            <!-- 縮小圖片容器高度 -->
                            <div class="d-flex align-items-center justify-content-center mb-2" style="height: 140px;">
                                @if (category.Image != null && category.Image.Length > 0)
                                {
                                    var base64 = Convert.ToBase64String(category.Image);
                                    var imgSrc = $"data:image/png;base64,{base64}";
                                    <img src="@imgSrc" class="img-fluid" style="max-height: 100%; object-fit: contain;" alt="@category.Name" />
                                }
                                else
                                {
                                    <div class="text-muted fs-2">📱</div>
                                }
                            </div>
                            <div class="card-body p-1">
                                <h3 class="card-title h5 fw-bold mb-1">@category.Name</h3>
                                <p class="text-primary m-0 small">探索更多 ➔</p>
                            </div>
                        </div>
                    </a>
                </div>
            }
        }

        @if (User.IsInRole("Admin"))
        {
            <div class="col">
                <a asp-controller="Categories" asp-action="Create" class="text-decoration-none text-dark">
                    <!-- 縮小新增按鈕的最小高度 -->
                    <div class="card home-category-card h-100 shadow-sm p-2 text-center d-flex flex-column align-items-center justify-content-center" style="border: 2px dashed #ccc; min-height: 200px;">
                        <div class="text-center w-100">
                            <div class="fs-2 mb-1">＋</div>
                            <h3 class="card-title h6 fw-bold m-0">新增類別</h3>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<!-- 縮小底部 CTA 區塊的間距 -->
<div class="container-fluid py-3 my-3" style="background-color: var(--apple-gray-bg, #f5f5f7); border-radius: 16px;">
    <div class="row justify-content-center text-center">
        <div class="col-lg-6">
            <h4 class="fw-bold mb-2">開啟您的 愛瘋屋 體驗</h4>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <p class="text-muted mb-3 small">您已成功登入帳戶，立即開始探索我們為您精選的優質蘋果商品！</p>
                <div class="d-flex justify-content-center">
                    <a asp-controller="Products" asp-action="Index" class="btn btn-primary px-4 py-2">開始選購商品</a>
                </div>
            }
            else
            {
                <p class="text-muted mb-3 small">登入以同步您的購物車，或以訪客身份探索最新商品。</p>
                <div class="d-flex justify-content-center gap-2">
                    <a asp-controller="Account" asp-action="Register" class="btn btn-success btn-sm px-3">註冊</a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-sm px-3">登入</a>
                </div>
            }
        </div>
    </div>
</div>