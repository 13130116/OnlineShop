@model IEnumerable<OnlineShop.Models.Category>

@{
    ViewData["Title"] = "首頁";
}

<div class="text-center my-5 py-4">
    <h1 class="display-3 fw-bold mb-2" style="letter-spacing: -1px;">歡迎來到愛瘋屋</h1>
    <p class="fs-4 text-muted">請選擇商品類別</p>
</div>

<div class="container mb-5">
    <div class="row row-cols-1 row-cols-md-3 g-4 justify-content-center">
        @if (Model != null && Model.Any())
        {
            @foreach (var category in Model)
            {
                <div class="col">
                    <a asp-controller="Products" asp-action="Index" asp-route-categoryId="@category.Id" class="text-decoration-none text-dark">
                        <div class="card home-category-card h-100 shadow-sm p-3 text-center">

                            <div class="d-flex align-items-center justify-content-center mb-4" style="height: 180px;">
                                @if (category.Image != null && category.Image.Length > 0)
                                {
                                    var base64 = Convert.ToBase64String(category.Image);
                                    var imgSrc = $"data:image/png;base64,{base64}";
                                    <img src="@imgSrc" class="img-fluid" style="max-height: 100%; object-fit: contain;" alt="@category.Name" />
                                }
                                else
                                {
                                    <div class="text-muted fs-1">📱</div>
                                }
                            </div>

                            <div class="card-body p-0">
                                <h3 class="card-title h4 fw-bold mb-2">@category.Name</h3>
                                <p class="text-primary m-0 small">探索更多 ➔</p>
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted">目前暫無設定任何類別，請至後台管理新增。</p>
            </div>
        }
    </div>
</div>

<div class="container-fluid py-5 my-5" style="background-color: var(--apple-gray-bg); border-radius: 24px;">
    <div class="row justify-content-center text-center">
        <div class="col-lg-6">
            <h3 class="fw-bold mb-3">開啟您的 愛瘋屋 體驗</h3>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <p class="text-muted mb-4">您已成功登入帳戶，立即開始探索我們精選的蘋果官網認證福利品！</p>

                <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
                    <a asp-controller="Products" asp-action="Index" class="btn btn-primary btn-lg px-4 py-3 fs-6">
                        開始選購商品
                    </a>
                </div>
            }
            else
            {
                <p class="text-muted mb-4">登入以同步您的購物車，或以訪客身份直接探索我們精選的蘋果官網認證福利品。</p>

                <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
                    <a asp-controller="Account" asp-action="Register" class="btn btn-success btn-lg px-4 py-3 fs-6">
                        註冊專屬帳號
                    </a>

                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg px-4 py-3 fs-6">
                        登入會員帳戶
                    </a>

                    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-dark btn-lg px-4 py-3 fs-6" style="border-radius: 980px;">
                        隨意訪客瀏覽
                    </a>
                </div>
            }
        </div>
    </div>
</div>